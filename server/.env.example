# Postgres
DATABASE_URL=postgres://btm:CHANGE_ME@localhost:5432/btm

# Server
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# Better-Auth
BETTER_AUTH_SECRET=CHANGE_ME_TO_RANDOM_64_HEX
BETTER_AUTH_URL=https://your-instance.example

# Cookies / CSRF
TRUSTED_ORIGINS=https://your-instance.example

# Magic-Link Initial-Admin (Auto-Promotion beim 1. Login)
INITIAL_ADMIN_EMAIL=admin@example.com

# SMTP für Magic-Link / Einladungen
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME
SMTP_FROM="BTM <noreply@example.com>"

# Branding (optional — shown in emails and MCP description)
# APP_FULL_NAME=Bemany Task Management
# APP_ORG_NAME=Bemany
# APP_URL=https://your-instance.example

# AI-Provider für AI-Drawer + Chat-Bubble (OpenAI-Chat-Completions-Protokoll).
# Default: OpenAI mit gpt-4o-mini (schnell + günstig + solide Tool-Use).
# OPENAI_BASE_URL ist optional — für selbst gehostete OpenAI-kompatible
# Endpunkte (vLLM, LM-Studio, Anyscale, OpenRouter) hier umlenken.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Web-Push / VAPID (optional — für Push-Notifications an PWA-Nutzer)
# Generieren: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
