# Postgres
DATABASE_URL=postgres://btm:CHANGE_ME@localhost:5432/btm

# Server
PORT=3001
HOST=127.0.0.1
NODE_ENV=production

# Better-Auth
BETTER_AUTH_SECRET=CHANGE_ME_TO_RANDOM_64_HEX
BETTER_AUTH_URL=https://btm.bethesna.org

# Cookies / CSRF
TRUSTED_ORIGINS=https://btm.bethesna.org

# Magic-Link Initial-Admin (Auto-Promotion beim 1. Login)
INITIAL_ADMIN_EMAIL=esref@bemany.de

# SMTP für Magic-Link / Einladungen
SMTP_HOST=smtp.ionos.de
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=portal@meinfahrer.app
SMTP_PASS=CHANGE_ME
SMTP_FROM="BTM <portal@meinfahrer.app>"

# AI-Provider für AI-Drawer + Chat-Bubble (OpenAI-Chat-Completions-Protokoll).
# Default: OpenAI mit gpt-4o-mini (schnell + günstig + solide Tool-Use).
# OPENAI_BASE_URL ist optional — für selbst gehostete OpenAI-kompatible
# Endpunkte (vLLM, LM-Studio, Anyscale, OpenRouter) hier umlenken.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com

# Legacy (vor 2026-05-14, FkqjgMk6RH6): LM-Studio mit Gemma. Bleibt als
# Fallback aktiv wenn OPENAI_API_KEY nicht gesetzt ist — sonst ignoriert.
# LMSTUDIO_URL=https://llm1.bemany.tech
# LMSTUDIO_TOKEN=sk-lm-...
# LMSTUDIO_MODEL=google/gemma-4-e4b
